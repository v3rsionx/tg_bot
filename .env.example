# Configuration version
CONFIG_VERSION=1

# Logging
LOG_LEVEL=info

# Telegram
BOT_TOKEN=
BOT_OWNER_IDS=

# SQLite
SQLITE_PATH=./data/bot.db

# LMDB search indexes
LMDB_ID_PATH=./data/lmdb/id
LMDB_PHONE_PATH=./data/lmdb/phone
LMDB_USERNAME_PATH=./data/lmdb/username

# Runtime tuning
WORKER_COUNT=4
BATCH_SIZE=1000
SEARCH_TIMEOUT=5s
CACHE_TTL=5m
RATE_LIMIT=5

# Search limits
POINTS_PER_SEARCH=1
MAX_RESULTS=100
# Alias retained for compatibility:
# MAX_SEARCH_RESULT=100
